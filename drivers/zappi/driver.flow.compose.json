{
    "actions": [
        {
            "id": "unlock_charger",
            "title": {
                "en": "Unlock the charger",
                "no": "Lås opp laderen",
                "nl": "Ontgrendel de lader",
                "sv": "Lås upp laddaren",
                "de": "Ladegerät entsperren"
            },
            "hint": {
                "en": "Allow a charge session on a locked Zappi, the same as the unlock in the myenergi app.",
                "no": "Tillat en ladeøkt på en låst Zappi, det samme som opplåsing i myenergi-appen.",
                "nl": "Sta een laadsessie toe op een vergrendelde Zappi, hetzelfde als ontgrendelen in de myenergi-app.",
                "sv": "Tillåt en laddningssession på en låst Zappi, samma som upplåsningen i myenergi-appen.",
                "de": "Erlaubt eine Ladesitzung an einem gesperrten Zappi, wie das Entsperren in der myenergi-App."
            }
        },
        {
            "id": "start_charging",
            "title": {
                "en": "Start charging the car",
                "no": "Start lading av bilen",
                "nl": "Start laden van EV",
                "sv": "Börja ladda bilen",
                "de": "Ladevorgang des EV starten"
            }
        },
        {
            "id": "stop_charging",
            "title": {
                "en": "Stop charging the car",
                "no": "Stopp lading av bilen",
                "nl": "Stop laden van EV",
                "sv": "Sluta ladda bilen",
                "de": "Ladevorgang des EV beenden"
            }
        },
        {
            "id": "set_charge_mode",
            "title": {
                "en": "Set charge mode",
                "no": "Still inn Lademodus",
                "nl": "Laadmodus instellen",
                "sv": "Ställ in laddningsläge",
