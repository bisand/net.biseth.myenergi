{
  "name": {
    "en": "Libbi"
  },
  "class": "battery",
  "capabilities": [
    "measure_battery",
    "battery_charging_state",
    "measure_power",
    "libbi_mode_selector",
    "libbi_status",
    "measure_power_generated",
    "measure_voltage",
    "measure_frequency",
    "charge_session_consumption",
    "meter_power.charged",
    "meter_power.discharged",
    "button.reset_meter",
    "button.reload_capabilities"
  ],
  "energy": {
    "homeBattery": true,
    "meterPowerImportedCapability": "meter_power.charged",
    "meterPowerExportedCapability": "meter_power.discharged"
  },
  "capabilitiesOptions": {
    "libbi_mode_selector": {
      "preventTag": true,
      "preventInsights": true
    },
    "meter_power.charged": {
      "title": {
        "en": "Energy charged",
        "no": "Energi ladet",
        "nl": "Geladen energie",
        "sv": "Laddad energi",
        "de": "Geladene Energie"
      }
    },
    "meter_power.discharged": {
      "title": {
        "en": "Energy discharged",
        "no": "Energi utladet",
        "nl": "Ontladen energie",
        "sv": "Urladdad energi",
        "de": "Entladene Energie"
      }
    },
    "button.reset_meter": {
      "maintenanceAction": true,
      "title": {
        "en": "Reset energy meters",
        "no": "Tilbakestill strømmålere",
        "nl": "Reset energiemeters",
        "sv": "Återställ energimätarna",
        "de": "Energiezähler zurücksetzen"
      },
      "desc": {
        "en": "Reset the accumulated charged and discharged energy (kWh), this can not be restored.",
        "no": "Tilbakestill akkumulert ladet og utladet energi (kWh), dette kan ikke gjenopprettes.",
        "nl": "Reset de geaccumuleerde geladen en ontladen energie (kWh), dit kan niet worden hersteld.",
        "sv": "Återställ den ackumulerade laddade och urladdade energin (kWh), detta kan inte återställas.",
        "de": "Setzt die kumulierte geladene und entladene Energie zurück (kWh), diese kann nicht wiederhergestellt werden."
      }
    },
    "button.reload_capabilities": {
      "maintenanceAction": true,
      "title": {
        "en": "Reload capabilities"
      },
      "desc": {
        "en": "Reload sensor capabilities. Use this to reload sensor capabilities in case some of them are missing or are out of order."
      }
    },
    "measure_power": {
      "title": {
        "en": "Battery power",
        "no": "Batterieffekt",
        "nl": "Batterijvermogen",
        "sv": "Batterieffekt",
        "de": "Batterieleistung"
      }
    }
  },
  "platforms": [
    "local"
  ],
  "connectivity": [],
  "pair": [
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "next": "add_devices"
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "images": {
    "small": "{{driverAssetsPath}}/images/small.png",
    "large": "{{driverAssetsPath}}/images/large.png"
  }
}
